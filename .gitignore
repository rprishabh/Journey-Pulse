# ─────────────────────────────────────────────────────────────────
# TravelPulse India — .gitignore
# ─────────────────────────────────────────────────────────────────

# Dependencies
node_modules/

# Environment variables (NEVER commit secrets)
.env
.env.local
.env.production
.env.*.local

# Next.js build output
.next/
out/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Prisma
prisma/*.db
prisma/*.db-journal

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Vercel
.vercel/

# TypeScript
*.tsbuildinfo
